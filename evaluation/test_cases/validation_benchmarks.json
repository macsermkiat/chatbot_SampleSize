{
  "version": "1.0.0",
  "description": "Sample size validation benchmarks with exact expected values from published formulas. Sources: Chow et al. (2018) Sample Size Calculations in Clinical Research, Machin et al. (2018) Sample Sizes for Clinical, Laboratory and Epidemiology Studies, Julious (2023) Sample Sizes for Clinical Trials, Cohen (1988) Statistical Power Analysis for the Behavioral Sciences, statsmodels/scipy reference implementations, G*Power 3.1.",
  "benchmarks": [
    {
      "id": "V01",
      "scenario": "Two independent means (equal groups)",
      "description": "Compare mean systolic BP between drug and placebo. Two-sided two-sample t-test.",
      "parameters": {
        "test_type": "two_sample_t_test",
        "alpha": 0.05,
        "power": 0.80,
        "effect_size_type": "mean_difference",
        "mean_difference": 5.0,
        "sd": 12.0,
        "sides": 2,
        "allocation_ratio": 1.0
      },
      "expected": {
        "n_per_group": 91,
        "total_n": 182,
        "source": "Chow et al. Table 3.2.1; statsmodels TTestIndPower",
        "formula": "n = 2 * ((z_alpha/2 + z_beta) * sigma / delta)^2"
      },
      "tolerance_5pct": [87, 96],
      "tolerance_10pct": [82, 100]
    },
    {
      "id": "V02",
      "scenario": "Two independent means (unequal SD)",
      "description": "Compare pain scores. Group 1 SD=2.5, Group 2 SD=3.0, difference=1.5.",
      "parameters": {
        "test_type": "two_sample_t_test",
        "alpha": 0.05,
        "power": 0.80,
        "effect_size_type": "mean_difference",
        "mean_difference": 1.5,
        "sd_group1": 2.5,
        "sd_group2": 3.0,
        "sides": 2,
        "allocation_ratio": 1.0
      },
      "expected": {
        "n_per_group": 58,
        "total_n": 116,
        "source": "Pooled SD=2.76, d=0.543; statsmodels TTestIndPower",
        "formula": "n = 2 * ((z_alpha/2 + z_beta) / d)^2 with pooled SD"
      },
      "tolerance_5pct": [55, 61],
      "tolerance_10pct": [52, 64]
    },
    {
